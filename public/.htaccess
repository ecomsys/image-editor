RewriteEngine On

# Игнорируем реальные файлы и папки
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Игнорируем статические ассеты Vite
RewriteCond %{REQUEST_URI} !^/spa/image-editor/assets/
RewriteCond %{REQUEST_URI} !^/spa/image-editor/static/

# Всё остальное → index.html (SPA fallback)
RewriteRule ^ /spa/image-editor/index.html [L]